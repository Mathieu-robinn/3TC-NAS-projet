{
  "intent_version": "4.0",
  "addressing": {
    "loopback_pool": "1.0.0.0/8",
    "p2p_pool": "10.0.0.0/16",
    "customer_pool": "172.16.0.0/16",
    "p2p_prefix": 30,
    "ce_pe_prefix": 30
  },
  "autonomous_systems": {
    "AS1": {
      "asn": 1,
      "nodes": {
        "PE1": { "role": "PE" },
        "PE2": { "role": "PE" },
        "PE3": { "role": "PE" },
        "P1": { "role": "P" },
        "P2": { "role": "P" },
        "P3": { "role": "P" },
        "P4": { "role": "P" }
      },
      "links": [
        { "endpoints": [ { "node": "PE1", "interface": "GigabitEthernet1/0" }, { "node": "P1",  "interface": "GigabitEthernet1/0" } ], "igp_area": 0, "mpls": true },
        { "endpoints": [ { "node": "P1",  "interface": "GigabitEthernet2/0" }, { "node": "P2",  "interface": "GigabitEthernet2/0" } ], "igp_area": 0, "mpls": true },
        { "endpoints": [ { "node": "P1",  "interface": "GigabitEthernet3/0" }, { "node": "P3",  "interface": "GigabitEthernet3/0" } ], "igp_area": 10, "mpls": true },
        { "endpoints": [ { "node": "P3",  "interface": "GigabitEthernet2/0" }, { "node": "P4",  "interface": "GigabitEthernet1/0" } ], "igp_area": 10, "mpls": true },
        { "endpoints": [ { "node": "P2",  "interface": "GigabitEthernet3/0" }, { "node": "P4",  "interface": "GigabitEthernet2/0" } ], "igp_area": 0, "mpls": false },
        { "endpoints": [ { "node": "PE2", "interface": "GigabitEthernet1/0" }, { "node": "P2",  "interface": "GigabitEthernet1/0" } ], "igp_area": 0, "mpls": true },
        { "endpoints": [ { "node": "PE3", "interface": "GigabitEthernet1/0" }, { "node": "P3",  "interface": "GigabitEthernet1/0" } ], "igp_area": 10, "mpls": true }
      ],
      "underlay": {
        "igp": {
          "protocol": "ospf",
          "area": { "mode": "explicit" }
        },
        "mpls": {
          "enabled": true,
          "label_distribution": "ldp",
          "interfaces": { "mode": "explicit" }
        }
      },
      "bgp": {
        "type": "ibgp",
        "vpnv4": true,
        "route_reflectors": { "nodes": ["PE1", "PE2"] },
        "peering": { "strategy": "rr_redundant", "transport": "loopback" }
      }
    }
  },
  "customers": [
    {
      "name": "CUST1",
      "asn": 65001,
      "sites": [
        { "ce": "CE1-1", "pe": "PE1", "link": { "endpoints": [ { "node": "CE1-1", "interface": "GigabitEthernet2/0" }, { "node": "PE1", "interface": "GigabitEthernet2/0" } ] } },
        { "ce": "CE1-2", "pe": "PE3", "link": { "endpoints": [ { "node": "CE1-2", "interface": "GigabitEthernet2/0" }, { "node": "PE3", "interface": "GigabitEthernet2/0" } ] } }
      ]
    }
  ],
  "vpn_services": {
    "type": "l3vpn",
    "rd": { "mode": "asn_vrfid", "base": 100 },
    "rt": { "strategy": "auto_per_vrf" },
    "vrfs": [ { "name": "CUST1", "customer": "CUST1" } ]
  },
  "lan": {
    "enabled": true,
    "type": "subinterface_vlan",
    "addressing": { "base_pool": "10.0.0.0/8", "prefix": 32, "strategy": "per_site" },
    "subinterface": { "parent": "GigabitEthernet0/1", "vlan_base": 200 },
    "bgp": { "advertise": true, "method": "redistribute_connected" }
  }
}

