{
  "intent_version": "3.1",

  "addressing": {
    "loopback_pool": "1.0.0.0/8",
    "p2p_pool": "10.0.0.0/16",
    "customer_pool": "172.16.0.0/16",
    "p2p_prefix": 30,
    "customer_prefix": 24,
    "ce_pe_prefix": 30
  },

  "autogen_rules": {
    "loopbacks": {
      "strategy": "incremental_per_node"
    },
    "p2p_links": {
      "strategy": "incremental_per_link"
    },
    "customer_lans": {
      "strategy": "incremental_per_site"
    },
    "ce_pe_links": {
      "strategy": "incremental_per_link"
    }
  },

  "autonomous_systems": {
    "AS1": {
      "asn": 1,

      "nodes": {
        "PE1": { "role": "PE" },
        "PE2": { "role": "PE" },
        "PE3": { "role": "PE" },
        "P1":  { "role": "P" },
        "P2":  { "role": "P" },
        "P3":  { "role": "P" },
        "P4":  { "role": "P" }
      },

      "links": [
        {
          "endpoints": [
            { "node": "PE1", "interface": "GigabitEthernet1/0" },
            { "node": "P1",  "interface": "GigabitEthernet1/0" }
          ],
          "type": "core"
        },
        {
          "endpoints": [
            { "node": "P1", "interface": "GigabitEthernet2/0" },
            { "node": "P2", "interface": "GigabitEthernet2/0" }
          ],
          "type": "core"
        },
        {
          "endpoints": [
            { "node": "P1", "interface": "GigabitEthernet3/0" },
            { "node": "P3", "interface": "GigabitEthernet3/0" }
          ],
          "type": "core"
        },
        {
          "endpoints": [
            { "node": "P3", "interface": "GigabitEthernet2/0" },
            { "node": "P4", "interface": "GigabitEthernet1/0" }
          ],
          "type": "core"
        },
        {
          "endpoints": [
            { "node": "P2", "interface": "GigabitEthernet3/0" },
            { "node": "P4", "interface": "GigabitEthernet2/0" }
          ],
          "type": "core"
        },
        {
          "endpoints": [
            { "node": "PE2", "interface": "GigabitEthernet1/0" },
            { "node": "P2",  "interface": "GigabitEthernet1/0" }
          ],
          "type": "core"
        },
        {
          "endpoints": [
            { "node": "PE3", "interface": "GigabitEthernet1/0" },
            { "node": "P3",  "interface": "GigabitEthernet1/0" }
          ],
          "type": "core"
        }
      ],

      "underlay": {
        "igp": {
          "protocol": "ospf",
          "area_design": "single_area",
          "advertise": ["loopbacks", "core_links"]
        },
        "mpls": {
          "enabled": true,
          "label_distribution": "ldp",
          "enabled_on": ["core_links"]
        }
      },

      "bgp": {
        "type": "ibgp",
        "vpnv4": true,
        "route_reflector": {
          "enabled": true,
          "node": "PE1"
        },
        "peering": {
          "strategy": "rr_clients",
          "transport": "loopback"
        }
      }
    }
  },

  "customers": [
    {
      "name": "CUST1",
      "asn": 65001,
      "sites": [
        {
          "ce": "CE1-1",
          "pe": "PE1",
          "link": {
            "endpoints": [
              { "node": "CE1-1", "interface": "GigabitEthernet2/0" },
              { "node": "PE1",   "interface": "GigabitEthernet2/0" }
            ]
          }
        },
        {
          "ce": "CE1-2",
          "pe": "PE3",
          "link": {
            "endpoints": [
              { "node": "CE1-2", "interface": "GigabitEthernet2/0" },
              { "node": "PE3",   "interface": "GigabitEthernet2/0" }
            ]
          }
        }
      ]
    },
    {
      "name": "CUST2",
      "asn": 65002,
      "sites": [
        {
          "ce": "CE2-1",
          "pe": "PE1",
          "link": {
            "endpoints": [
              { "node": "CE2-1", "interface": "GigabitEthernet3/0" },
              { "node": "PE1",   "interface": "GigabitEthernet3/0" }
            ]
          }
        },
        {
          "ce": "CE2-2",
          "pe": "PE2",
          "link": {
            "endpoints": [
              { "node": "CE2-2", "interface": "GigabitEthernet2/0" },
              { "node": "PE2",   "interface": "GigabitEthernet2/0" }
            ]
          }
        }
      ]
    },
    {
      "name": "CUST3",
      "asn": 65003,
      "sites": [
        {
          "ce": "CE3-1",
          "pe": "PE3",
          "link": {
            "endpoints": [
              { "node": "CE3-1", "interface": "GigabitEthernet3/0" },
              { "node": "PE3",   "interface": "GigabitEthernet3/0" }
            ]
          }
        },
        {
          "ce": "CE3-2",
          "pe": "PE2",
          "link": {
            "endpoints": [
              { "node": "CE3-2", "interface": "GigabitEthernet3/0" },
              { "node": "PE2",   "interface": "GigabitEthernet3/0" }
            ]
          }
        }
      ]
    }
  ],

  "vpn_services": {
    "type": "l3vpn",
    "rd_strategy": "auto_per_vrf",
    "rt_strategy": "auto_per_vrf",
    "vrfs": [
      {
        "name": "CUST1",
        "customer": "CUST1"
      },
      {
        "name": "CUST2",
        "customer": "CUST2"
      },
      {
        "name": "CUST3",
        "customer": "CUST3"
      }
    ]
  },

  "pe_ce": {
    "routing": "ebgp",
    "addressing": {
      "strategy": "derived_from_customer_pool",
      "prefix": 30
    }
  },

  "policies": {
    "vpn_isolation": "strict",
    "intra_vpn_connectivity": "full_mesh",
    "inter_vpn_connectivity": "deny"
  },

  "validation": {
    "checks": [
      "unique loopback allocation per node",
      "unique p2p subnet allocation per core link",
      "unique ce-pe subnet allocation per access link",
      "igp converged in AS1",
      "ldp neighbors established on all core links",
      "route reflector sessions established",
      "vpnv4 routes exchanged between PE routers",
      "vrf separation enforced",
      "customer reachability only within same vpn"
    ]
  }
}